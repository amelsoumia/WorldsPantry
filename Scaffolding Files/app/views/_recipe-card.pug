//- Recipe preview cards to be displayed in browsing page


if !recipes || recipes.length === 0
  p There are currently no recipes.

else
  .recipes
    each recipe in recipes
      article
        if recipe.image_url
          img(src=recipe.image_url, alt=recipe.title)
        else
          img(src="/images/default-recipe-image.jpg", alt="Default Recipe Image")

        h3
          a(href=`/recipe/${recipe.recipe_id}`)= recipe.title

        p= recipe.country_name || 'International'
        p by #{recipe.username}

        if recipe.dietary_tags && recipe.dietary_tags.length
          ul
            each dietary in recipe.dietary_tags
              li= dietary.name